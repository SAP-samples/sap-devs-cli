{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Learning Journey References",
  "description": "Schema for sap-devs learning.yaml files",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "profile_filters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "products": {
          "type": "array",
          "items": { "type": "string" }
        },
        "product_categories": {
          "type": "array",
          "items": { "type": "string" }
        },
        "roles": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "journeys": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slug"],
        "additionalProperties": false,
        "properties": {
          "slug": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*[a-z0-9]$",
            "description": "URL slug from learning.sap.com/learning-journeys/{slug}"
          },
          "featured": {
            "type": "boolean",
            "default": false,
            "description": "If true, highlighted in list output and injected into AI context"
          }
        }
      }
    }
  }
}
